# Copiar a backend/.env y completar valores.

# Base de datos — SQL Server.
# Instancia con nombre (requiere SQL Browser activo):
#   sqlserver://HOST\INSTANCIA;database=OVA_RESIDENCIAL;user=sa;password=...;encrypt=true;trustServerCertificate=true
# Puerto fijo (alternativa sin SQL Browser):
#   sqlserver://HOST:1433;database=OVA_RESIDENCIAL;user=sa;password=...;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost\SQLEXPRESS;database=OVA_RESIDENCIAL;user=sa;password=tu_password;encrypt=true;trustServerCertificate=true"

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES=8h
JWT_REFRESH_EXPIRES=30d

PORT=3002
